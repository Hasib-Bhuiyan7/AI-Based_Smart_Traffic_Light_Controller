<?xml version="1.0" encoding="UTF-8"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">

    <vType id="toy_car" maxSpeed="13.0" accel="1" decel="1"/>

    <route id="N_to_S" edges="E9 E8"/>
    <route id="N_to_E" edges="E9 E7.61"/>
    <route id="N_to_W" edges="E9 -E7.68"/>

    <route id="S_to_N" edges="-E8 -E9"/>
    <route id="S_to_E" edges="-E8 E7.61"/>
    <route id="S_to_W" edges="-E8 -E7.68"/>

    <route id="E_to_W" edges="-E7 -E7.68"/>
    <route id="E_to_N" edges="-E7 -E9"/>
    <route id="E_to_S" edges="-E7 E8"/>

    <route id="W_to_E" edges="E7 E7.61"/>
    <route id="W_to_N" edges="E7 -E9"/>
    <route id="W_to_S" edges="E7 E8"/>

    <!-- Normal hour, randomized departures, insertion-friendly -->
    <flow id="N_right"   type="toy_car" route="N_to_W" begin="0" number="40"  period="exp(0.011111)" departLane="best" departPos="last" departSpeed="desired"/>
    <flow id="N_through" type="toy_car" route="N_to_S" begin="0" number="244" period="exp(0.067778)" departLane="best" departPos="last" departSpeed="desired"/>
    <flow id="N_left"    type="toy_car" route="N_to_E" begin="0" number="33"  period="exp(0.009167)" departLane="best" departPos="last" departSpeed="desired"/>

    <flow id="S_right"   type="toy_car" route="S_to_E" begin="0" number="23"  period="exp(0.006389)" departLane="best" departPos="last" departSpeed="desired"/>
    <flow id="S_through" type="toy_car" route="S_to_N" begin="0" number="235" period="exp(0.065278)" departLane="best" departPos="last" departSpeed="desired"/>
    <flow id="S_left"    type="toy_car" route="S_to_W" begin="0" number="46"  period="exp(0.012778)" departLane="best" departPos="last" departSpeed="desired"/>

    <flow id="E_right"   type="toy_car" route="E_to_N" begin="0" number="39"  period="exp(0.010833)" departLane="best" departPos="last" departSpeed="desired"/>
    <flow id="E_through" type="toy_car" route="E_to_W" begin="0" number="272" period="exp(0.075556)" departLane="best" departPos="last" departSpeed="desired"/>
    <flow id="E_left"    type="toy_car" route="E_to_S" begin="0" number="23"  period="exp(0.006389)" departLane="best" departPos="last" departSpeed="desired"/>

    <flow id="W_right"   type="toy_car" route="W_to_S" begin="0" number="51"  period="exp(0.014167)" departLane="best" departPos="last" departSpeed="desired"/>
    <flow id="W_through" type="toy_car" route="W_to_E" begin="0" number="350" period="exp(0.097222)" departLane="best" departPos="last" departSpeed="desired"/>
    <flow id="W_left"    type="toy_car" route="W_to_N" begin="0" number="40"  period="exp(0.011111)" departLane="best" departPos="last" departSpeed="desired"/>

</routes>