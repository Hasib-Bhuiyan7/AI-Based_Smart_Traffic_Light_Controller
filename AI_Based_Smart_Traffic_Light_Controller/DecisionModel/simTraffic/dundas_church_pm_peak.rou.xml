<?xml version="1.0" encoding="UTF-8"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">

    <vType id="toy_car" maxSpeed="13.0" accel="1" decel="1"/>

    <!-- Routes -->
    <route id="N_to_S" edges="E9 E8"/>
    <route id="N_to_E" edges="E9 E7.61"/>
    <route id="N_to_W" edges="E9 -E7.68"/>

    <route id="S_to_N" edges="-E8 -E9"/>
    <route id="S_to_E" edges="-E8 E7.61"/>
    <route id="S_to_W" edges="-E8 -E7.68"/>

    <route id="E_to_W" edges="-E7 -E7.68"/>
    <route id="E_to_N" edges="-E7 -E9"/>
    <route id="E_to_S" edges="-E7 E8"/>

    <route id="W_to_E" edges="E7 E7.61"/>
    <route id="W_to_N" edges="E7 -E9"/>
    <route id="W_to_S" edges="E7 E8"/>

    <!-- Real PM peak turning counts for 1 hour -->
    <!-- North -->
    <flow id="N_right"   type="toy_car" route="N_to_W" begin="0" end="3600" vehsPerHour="46"  departLane="best" departSpeed="max"/>
    <flow id="N_through" type="toy_car" route="N_to_S" begin="0" end="3600" vehsPerHour="293" departLane="best" departSpeed="max"/>
    <flow id="N_left"    type="toy_car" route="N_to_E" begin="0" end="3600" vehsPerHour="52"  departLane="best" departSpeed="max"/>

    <!-- South -->
    <flow id="S_right"   type="toy_car" route="S_to_E" begin="0" end="3600" vehsPerHour="29"  departLane="best" departSpeed="max"/>
    <flow id="S_through" type="toy_car" route="S_to_N" begin="0" end="3600" vehsPerHour="332" departLane="best" departSpeed="max"/>
    <flow id="S_left"    type="toy_car" route="S_to_W" begin="0" end="3600" vehsPerHour="57"  departLane="best" departSpeed="max"/>

    <!-- East -->
    <flow id="E_right"   type="toy_car" route="E_to_N" begin="0" end="3600" vehsPerHour="42"  departLane="best" departSpeed="max"/>
    <flow id="E_through" type="toy_car" route="E_to_W" begin="0" end="3600" vehsPerHour="255" departLane="best" departSpeed="max"/>
    <flow id="E_left"    type="toy_car" route="E_to_S" begin="0" end="3600" vehsPerHour="31"  departLane="best" departSpeed="max"/>

    <!-- West -->
    <flow id="W_right"   type="toy_car" route="W_to_S" begin="0" end="3600" vehsPerHour="46"  departLane="best" departSpeed="max"/>
    <flow id="W_through" type="toy_car" route="W_to_E" begin="0" end="3600" vehsPerHour="501" departLane="best" departSpeed="max"/>
    <flow id="W_left"    type="toy_car" route="W_to_N" begin="0" end="3600" vehsPerHour="36"  departLane="best" departSpeed="max"/>

</routes>